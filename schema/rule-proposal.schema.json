{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-canon.dev/schema/rule-proposal.schema.json",
  "title": "Design Canon Rule Proposal",
  "description": "A candidate anti-slop rule proposal for Design Canon. Proposed IDs are suggestions only.",
  "type": "object",
  "required": [
    "proposalId",
    "proposedRuleId",
    "title",
    "category",
    "relevantSurfaces",
    "summary",
    "instruction",
    "rationale",
    "claimType",
    "violations",
    "controls",
    "borderlineCases",
    "contextualExceptions",
    "detectorFeasibility",
    "detectorSignal",
    "matcherProposal",
    "detectorLimitations",
    "impact",
    "falsePositiveRisk",
    "falsePositiveScenarios",
    "mitigationStrategy",
    "fixturePlans",
    "status",
    "cleanRoomAttestations"
  ],
  "properties": {
    "proposalId": {
      "type": "string",
      "pattern": "^P-[A-Z]{1,3}-[0-9]{3}$",
      "description": "Proposal identifier, track-specific"
    },
    "proposedRuleId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
      "description": "Suggested rule ID. Not an accepted public ID."
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "category": {
      "type": "string",
      "enum": [
        "color",
        "typography",
        "spacing",
        "layout",
        "hierarchy",
        "radii",
        "borders",
        "depth",
        "motion",
        "responsive",
        "navigation",
        "forms",
        "tables",
        "dashboards",
        "marketing-surfaces",
        "editorial-surfaces",
        "mobile-interfaces",
        "loading-states",
        "empty-states",
        "error-states",
        "badges-indicators",
        "data-integrity",
        "accessibility",
        "ai-copy",
        "ui-patterns"
      ]
    },
    "relevantSurfaces": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "instruction": {
      "type": "string",
      "minLength": 20,
      "description": "Concise instruction that could become a rule's instruction field"
    },
    "rationale": {
      "type": "string",
      "minLength": 20
    },
    "claimType": {
      "type": "string",
      "enum": [
        "observation",
        "research-backed",
        "hybrid",
        "general-knowledge"
      ]
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SRC-[A-Z0-9]{6}$"
      },
      "description": "References to source registry entries. Required for research-backed and hybrid claims."
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "minItems": 2,
      "description": "At least two example violations"
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "minItems": 2,
      "description": "At least two legitimate controls where the rule does not apply"
    },
    "borderlineCases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "minItems": 1,
      "description": "At least one borderline case"
    },
    "contextualExceptions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "When to suppress or relax the rule"
    },
    "detectorFeasibility": {
      "type": "string",
      "enum": [
        "definitive",
        "heuristic",
        "visual-only",
        "not-feasible"
      ]
    },
    "detectorSignal": {
      "type": "string",
      "minLength": 5,
      "description": "What the detector looks for in source code, rendered output, or behavior"
    },
    "matcherProposal": {
      "type": "string",
      "description": "Pattern-matching strategy without executable regex. Describe the approach."
    },
    "detectorLimitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "impact": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "falsePositiveRisk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "very-high"
      ]
    },
    "falsePositiveScenarios": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
    },
    "mitigationStrategy": {
      "type": "string",
      "minLength": 10
    },
    "fixturePlans": {
      "type": "object",
      "required": [
        "violation",
        "control",
        "borderline"
      ],
      "properties": {
        "violation": {
          "type": "string",
          "minLength": 10
        },
        "control": {
          "type": "string",
          "minLength": 10
        },
        "borderline": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review-ready",
        "needs-research",
        "parked"
      ]
    },
    "cleanRoomAttestations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Clean-room independence attestations"
    },
    "overlapNotes": {
      "type": "string",
      "description": "Notes on overlap with existing rules or other proposals (Track F)"
    }
  },
  "additionalProperties": false
}