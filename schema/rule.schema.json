{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-canon.dev/schema/rule.schema.json",
  "title": "Design Canon Rule",
  "type": "object",
  "required": ["id", "category", "title", "severity", "appliesTo", "instruction"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
    "category": { "type": "string" },
    "title": { "type": "string", "minLength": 3 },
    "severity": { "enum": ["error", "warning", "info"] },
    "appliesTo": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "instruction": { "type": "string", "minLength": 20 },
    "rationale": { "type": "string" },
    "verify": { "type": "array", "items": { "type": "string" } },
    "detect": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" },
        "patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source"],
            "properties": {
              "source": { "type": "string" },
              "flags": { "type": "string" },
              "multiple": { "type": "boolean" }
            }
          }
        },
        "browserAnalyzer": {
          "type": "object",
          "required": ["id", "extensions"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "extensions": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^\\.[a-z0-9]+$"
              },
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      },
      "oneOf": [
        { "required": ["patterns"] },
        { "required": ["browserAnalyzer"] }
      ]
    }
  },
  "additionalProperties": false
}
