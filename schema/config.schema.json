{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/asimons81/design-canon/raw/main/schema/config.schema.json",
  "title": "Design Canon configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "const": 1
    },
    "profile": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "suppressions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule", "files", "reason"],
        "properties": {
          "rule": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reason": {
            "type": "string",
            "minLength": 12
          },
          "approvedBy": {
            "type": "string",
            "minLength": 1
          },
          "expires": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}
