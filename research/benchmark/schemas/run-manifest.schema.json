{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/asimons81/design-canon/research/benchmark/schemas/run-manifest.schema.json",
  "title": "Design Canon Benchmark Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "protocolVersion",
    "protocolId",
    "benchmarkId",
    "runId",
    "condition",
    "repetition",
    "executionOrder",
    "profile",
    "status",
    "briefHash",
    "assembledInstructionHash",
    "instructionBytes",
    "selectedRuleIds",
    "environment",
    "limits",
    "viewportResults",
    "invalidReason"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "protocolVersion": { "type": "string", "minLength": 1 },
    "protocolId": { "type": "string", "minLength": 1 },
    "benchmarkId": { "type": "string", "pattern": "^B0(0[1-9]|1[0-5])$" },
    "runId": { "type": "string", "pattern": "^B0(0[1-9]|1[0-5])-[ABCD]-r[1-9][0-9]*$" },
    "condition": { "enum": ["A", "B", "C", "D"] },
    "repetition": { "type": "integer", "minimum": 1 },
    "executionOrder": { "type": "integer", "minimum": 1, "maximum": 4 },
    "profile": { "enum": ["marketing", "product-app", "editorial"] },
    "status": { "enum": ["planned", "running", "complete", "partial", "failed", "invalid"] },
    "startedAt": { "type": ["string", "null"], "format": "date-time" },
    "completedAt": { "type": ["string", "null"], "format": "date-time" },
    "model": { "type": ["string", "null"] },
    "modelVersion": { "type": ["string", "null"] },
    "agentFramework": { "type": ["string", "null"] },
    "agentVersion": { "type": ["string", "null"] },
    "sampling": { "type": ["object", "null"] },
    "catalogCommit": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40}$" },
    "selectedRuleIds": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "briefPath": { "type": "string" },
    "briefHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "guidancePath": { "type": ["string", "null"] },
    "guidanceHash": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
    "assembledInstructionsPath": { "type": "string" },
    "assembledInstructionHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "instructionCharacters": { "type": "integer", "minimum": 0 },
    "instructionBytes": { "type": "integer", "minimum": 0 },
    "instructionTokens": { "type": ["integer", "null"], "minimum": 0 },
    "tokenizer": { "type": ["string", "null"] },
    "usage": { "type": ["object", "null"] },
    "estimatedCost": { "type": ["object", "null"] },
    "runtimeMs": { "type": ["integer", "null"], "minimum": 0 },
    "actionCount": { "type": ["integer", "null"], "minimum": 0 },
    "environment": { "type": "object" },
    "limits": { "type": "object" },
    "viewportResults": { "type": "array" },
    "lintReportPath": { "type": ["string", "null"] },
    "accessibilityReportPath": { "type": ["string", "null"] },
    "artifactHashesPath": { "type": ["string", "null"] },
    "invalidReason": { "type": ["string", "null"] }
  }
}
